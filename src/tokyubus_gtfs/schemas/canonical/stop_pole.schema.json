{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical/stop_pole.schema.json",
  "title": "CanonicalStopPole",
  "type": "object",
  "required": ["stop_pole_id", "stop_id"],
  "properties": {
    "stop_pole_id": { "type": "string" },
    "stop_id": { "type": "string" },
    "stop_name": { "type": "string" },
    "pole_number": { "type": ["string", "null"] },
    "lat": { "type": ["number", "null"] },
    "lon": { "type": ["number", "null"] },
    "odpt_id": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical/trip_stop_time.schema.json",
  "title": "CanonicalTripStopTime",
  "description": "Arrival/departure at each stop within a trip.",
  "type": "object",
  "required": ["trip_id", "stop_id", "stop_sequence"],
  "properties": {
    "trip_id": { "type": "string" },
    "stop_id": { "type": "string" },
    "stop_sequence": { "type": "integer", "minimum": 0 },
    "arrival_time": { "type": ["string", "null"], "description": "HH:MM:SS" },
    "departure_time": { "type": ["string", "null"] },
    "arrival_seconds": { "type": ["integer", "null"] },
    "departure_seconds": { "type": ["integer", "null"] },
    "stop_name": { "type": "string" },
    "odpt_raw_arrival": { "type": ["string", "null"], "description": "Original ODPT arrival string" },
    "odpt_raw_departure": { "type": ["string", "null"], "description": "Original ODPT departure string" }
  }
}

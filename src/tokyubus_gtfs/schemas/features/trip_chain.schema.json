{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "features/trip_chain.schema.json",
  "title": "TripChainCandidate",
  "description": "Research feature: candidate consecutive trip pair for vehicle duty construction.",
  "type": "object",
  "required": ["service_id", "trip_i_id", "trip_j_id"],
  "properties": {
    "service_id": { "type": "string" },
    "trip_i_id": { "type": "string" },
    "trip_j_id": { "type": "string" },
    "trip_i_route": { "type": "string" },
    "trip_j_route": { "type": "string" },
    "gap_min": { "type": "number", "minimum": 0 },
    "needs_deadhead": { "type": "boolean" },
    "dest_i": { "type": "string" },
    "origin_j": { "type": "string" },
    "feasible": { "type": "boolean" }
  }
}

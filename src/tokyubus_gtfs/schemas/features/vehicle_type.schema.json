{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "features/vehicle_type.schema.json",
  "title": "VehicleType",
  "type": "object",
  "required": ["vehicle_type_id", "label"],
  "properties": {
    "vehicle_type_id": { "type": "string" },
    "label": { "type": "string" },
    "powertrain": { "type": "string" },
    "battery_kwh": { "type": ["number", "null"], "minimum": 0 },
    "min_soc": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "max_soc": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sidecar/route_pattern.schema.json",
  "title": "SidecarRoutePattern",
  "description": "GTFS sidecar: route pattern metadata that GTFS core cannot represent.",
  "type": "object",
  "required": ["route_id"],
  "properties": {
    "route_id": { "type": "string" },
    "odpt_pattern_id": { "type": "string" },
    "odpt_busroute_id": { "type": "string" },
    "route_code": { "type": "string" },
    "route_name": { "type": "string" },
    "route_family_code": { "type": ["string", "null"] },
    "route_variant_type": { "type": "string" },
    "canonical_direction": { "type": "string" },
    "classification_confidence": { "type": "number" },
    "classification_reasons": { "type": "array", "items": { "type": "string" } },
    "stop_sequence": { "type": "array", "items": { "type": "string" } }
  }
}

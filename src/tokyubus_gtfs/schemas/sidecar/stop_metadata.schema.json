{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sidecar/stop_metadata.schema.json",
  "title": "SidecarStopMetadata",
  "description": "GTFS sidecar: stop coordinate provenance and ODPT metadata.",
  "type": "object",
  "required": ["stop_id"],
  "properties": {
    "stop_id": { "type": "string" },
    "odpt_id": { "type": "string" },
    "coord_source_type": { "type": "string" },
    "coord_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "pole_number": { "type": ["string", "null"] }
  }
}

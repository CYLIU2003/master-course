{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "features/energy_estimate.schema.json",
  "title": "TripEnergyEstimate",
  "description": "Research feature: per-trip energy consumption estimate.",
  "type": "object",
  "required": ["trip_id"],
  "properties": {
    "trip_id": { "type": "string" },
    "route_id": { "type": "string" },
    "distance_km": { "type": "number", "minimum": 0 },
    "bev_kwh_estimate": { "type": "number", "minimum": 0 },
    "ice_l_estimate": { "type": "number", "minimum": 0 },
    "estimation_method": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}

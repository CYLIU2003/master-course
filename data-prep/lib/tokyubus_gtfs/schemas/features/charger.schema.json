{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "features/charger.schema.json",
  "title": "Charger",
  "type": "object",
  "required": ["charger_id", "depot_id"],
  "properties": {
    "charger_id": { "type": "string" },
    "depot_id": { "type": "string" },
    "power_kw": { "type": "number", "minimum": 0 },
    "connector_type": { "type": "string" },
    "compatible_vehicle_types": { "type": "array", "items": { "type": "string" } }
  }
}

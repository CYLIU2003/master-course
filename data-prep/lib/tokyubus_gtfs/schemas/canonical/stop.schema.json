{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical/stop.schema.json",
  "title": "CanonicalStop",
  "description": "Normalised bus stop / pole for the Tokyu Bus canonical transit model.",
  "type": "object",
  "required": ["stop_id", "stop_name"],
  "properties": {
    "stop_id": { "type": "string", "description": "Unique stop identifier (ODPT URI or generated)" },
    "stop_code": { "type": "string", "description": "Short display code" },
    "stop_name": { "type": "string", "description": "Stop name (Japanese)" },
    "stop_name_en": { "type": "string", "description": "Stop name (English)" },
    "lat": { "type": ["number", "null"], "description": "WGS84 latitude" },
    "lon": { "type": ["number", "null"], "description": "WGS84 longitude" },
    "coord_source_type": {
      "type": "string",
      "enum": ["odpt_direct", "gtfs_import", "geocoded", "imputed_mean", "imputed_snap", "unknown"],
      "description": "How the coordinate was obtained"
    },
    "coord_confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Coordinate quality score" },
    "pole_number": { "type": ["string", "null"], "description": "ODPT busstopPoleNumber" },
    "parent_station_id": { "type": ["string", "null"] },
    "zone_id": { "type": ["string", "null"] },
    "odpt_id": { "type": "string", "description": "Original ODPT identifier" },
    "odpt_raw": { "type": "object", "description": "Selected raw ODPT fields for provenance" }
  }
}

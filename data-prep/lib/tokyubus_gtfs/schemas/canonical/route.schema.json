{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical/route.schema.json",
  "title": "CanonicalRoute",
  "description": "Normalised route (one per ODPT BusroutePattern).",
  "type": "object",
  "required": ["route_id", "route_name"],
  "properties": {
    "route_id": { "type": "string" },
    "route_code": { "type": "string" },
    "route_name": { "type": "string" },
    "route_name_en": { "type": "string" },
    "operator_id": { "type": "string" },
    "route_color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "route_type": { "type": "integer", "description": "GTFS route_type (3=bus)" },
    "origin_stop_id": { "type": "string" },
    "destination_stop_id": { "type": "string" },
    "origin_name": { "type": "string" },
    "destination_name": { "type": "string" },
    "distance_km": { "type": "number", "minimum": 0 },
    "trip_count": { "type": "integer", "minimum": 0 },
    "stop_count": { "type": "integer", "minimum": 0 },
    "odpt_pattern_id": { "type": "string" },
    "odpt_busroute_id": { "type": "string" },
    "odpt_raw_title": { "type": "string" },
    "route_family_code": { "type": ["string", "null"] },
    "route_family_label": { "type": ["string", "null"] },
    "route_variant_type": {
      "type": "string",
      "enum": ["main", "main_outbound", "main_inbound", "short_turn", "branch", "depot_out", "depot_in", "unknown"]
    },
    "canonical_direction": {
      "type": "string",
      "enum": ["outbound", "inbound", "circular", "unknown"]
    },
    "is_primary_variant": { "type": "boolean" },
    "family_sort_order": { "type": "integer" },
    "classification_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classification_reasons": { "type": "array", "items": { "type": "string" } }
  }
}

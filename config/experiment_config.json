{
  "_comment": "仕様書 §12.10 config.json - 実験設定ファイル (tokyu_core 4営業所)",
  "_cases": {
    "_note": "段階的スケールアップ: toy → S1(meguro_small) → S2(meguro_full) → S3(4-depot)",
    "toy": "config/cases/toy_mode_A_case01.json",
    "S1_meguro_small": "config/cases/meguro_small.json",
    "S2_meguro_full":   "config/cases/meguro_full.json",
    "S3_seta_full":      "config/cases/seta_full.json",
    "S3_awashima_full":  "config/cases/awashima_full.json",
    "S3_tsurumaki_full": "config/cases/tsurumaki_full.json"
  },
  "_active_case": "S1_meguro_small",
  "time_step_min": 15,
  "num_periods": 64,
  "start_time": "05:00",
  "end_time": "21:00",
  "planning_horizon_hours": 16.0,

  "allow_partial_service": false,
  "enable_pv": false,
  "enable_v2g": false,
  "enable_battery_degradation": false,
  "enable_demand_charge": false,
  "use_soft_soc_constraint": false,

  "solver": {
    "time_limit_sec": 300,
    "mip_gap": 0.01,
    "threads": 0,
    "presolve": -1,
    "verbose": false
  },

  "objective_weights": {
    "vehicle_fixed_cost": 1.0,
    "electricity_cost": 1.0,
    "demand_charge_cost": 1.0,
    "fuel_cost": 1.0,
    "deadhead_cost": 1.0,
    "battery_degradation_cost": 1.0,
    "emission_cost": 0.0,
    "unserved_penalty": 10000.0,
    "slack_penalty": 1000000.0
  },

  "big_m": {
    "BIG_M_ASSIGN": 1000000,
    "BIG_M_CHARGE": 1000000,
    "BIG_M_SOC": 1000000,
    "EPSILON": 1e-6
  },

  "paths": {
    "vehicles_csv": "data/toy/vehicles.csv",
    "tasks_csv": "data/toy/tasks.csv",
    "chargers_csv": "data/toy/chargers.csv",
    "sites_csv": "data/toy/sites.csv",
    "pv_profile_csv": "data/toy/pv_profile.csv",
    "electricity_price_csv": "data/toy/electricity_price.csv",
    "travel_connection_csv": "data/toy/travel_connection.csv",
    "compat_vehicle_task_csv": "data/toy/compatibility_vehicle_task.csv",
    "compat_vehicle_charger_csv": "data/toy/compatibility_vehicle_charger.csv",
    "output_dir": "outputs"
  },

  "_comment_v3": "=== spec_v3 §11 追加フィールド (2 層構造・route-editable 対応) ===",

  "mode": "thesis_mode_route_editable",
  "dispatch_preprocess": {
    "_comment": "travel_connection 生成ルート切替: dispatch_graph | build_inputs | none",
    "enabled": true,
    "connection_source": "dispatch_graph",
    "rebuild_when_missing": true,
    "force_rebuild_travel_connections": false,
    "default_turnaround_min": 10,
    "turnaround_rules_csv": "data/operations/turnaround_rules.csv",
    "deadhead_rules_csv": "data/operations/deadhead_rules.csv",
    "replace_tasks_from_build_inputs": true
  },
  "energy_model_level": 1,
  "fuel_model_enabled": true,
  "allow_deadhead": true,
  "allow_partial_charging": true,
  "service_day_type": "weekday",
  "route_length_multiplier": 1.0,

  "uncertainty": {
    "enabled": false,
    "n_scenarios": 10,
    "seed": 42,
    "energy_range": [0.85, 1.15],
    "travel_time_range": [0.90, 1.20],
    "congestion_range": [0.95, 1.30],
    "temp_range": [-5.0, 5.0],
    "load_range": [0.5, 1.0],
    "rain_range": [0.0, 1.0]
  },

  "route_edit_rules": {
    "_comment": "route-detail 層のパラメータ上書きルール (thesis_mode_route_editable 用)",
    "segment_distance_overrides": {},
    "segment_grade_overrides": {},
    "timetable_headway_overrides": {},
    "powertrain_comparison": ["BEV", "ICE", "HEV"]
  },

  "duty_assignment": {
    "_comment": "行路設定表による車両配分 (spec_v3 §6)",
    "enabled": false,
    "duties_csv_path": "data/fleet/vehicle_duties.csv",
    "duty_legs_csv_path": "data/fleet/duty_legs.csv",
    "allow_duty_swap": false,
    "enforce_depot_match": true,
    "enforce_vehicle_type_match": true
  },

  "alns": {
    "_comment": "ALNS パラメータ (mode_alns_only / mode_alns_milp 共通)",
    "max_iterations": 500,
    "max_no_improve": 100,
    "init_temp": 1000.0,
    "cooling_rate": 0.995,
    "destroy_ratio_min": 0.1,
    "destroy_ratio_max": 0.4,
    "seed": 42
  },

  "milp_flag_overrides": null,

  "soc_threshold": {
    "_comment": "SOC 閾値自動充電 (§10.5 拡張)",
    "enabled": false,
    "trigger_ratio": 0.20,
    "resume_ratio": 0.40
  },

  "depot_charger_cost": {
    "_comment": "デポ・充電器コストモデリング",
    "depot_detour_cost_per_km": 80.0,
    "charger_daily_fixed_cost": 500.0,
    "depots_csv_path": "data/infra/depots.csv",
    "depot_charger_distances_csv_path": "data/infra/depot_charger_distances.csv"
  },

  "gap_analysis": {
    "_comment": "最適化 vs シミュレーション ギャップ分析 (spec_v3 §9)",
    "enabled": false
  },

  "delay_resilience_test": {
    "_comment": "遅延耐性テスト (spec_v3 §10)",
    "enabled": false,
    "n_scenarios": 10,
    "delay_probability": 0.15,
    "delay_mean_min": 5.0,
    "seed": 42
  },

  "passenger_load": {
    "_comment": "乗客負荷プロファイル (spec_v3 §7)",
    "enabled": false,
    "csv_path": "data/external/passenger_load_profile.csv",
    "default_load_factor": 0.5
  },

  "tariff": {
    "_comment": "TOU 電力料金従量 (spec_v3 §9)",
    "enabled": false,
    "csv_path": "data/external/tariff.csv"
  },

  "v3_data_dir": "data",
  "route_master_dir": "data/route_master",
  "fleet_dir": "data/fleet",
  "infra_dir": "data/infra",
  "external_dir": "data/external",
  "derived_dir": "data/derived"
}

.env
.env.*
*.env

# Compiled python (explicit)
*.pyc

# Databases and caches
*.sqlite3
*.sqlite
*.db

# Misc
*.log
*.zip
*.tar.gz


# Legacy cache locations (kept ignored for backward compatibility)
data/cache/
data/odpt_subset_cache
data/built/odpt_subset_cache


{
  "$id": "https://master-course/schemas/optimize-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptimizeRequest",
  "type": "object",
  "required": ["scenario_id"],
  "properties": {
    "scenario_id": { "type": "string" },
    "solver_mode": {
      "type": "string",
      "enum": ["milp", "alns", "hybrid", "ga", "abc"],
      "default": "hybrid"
    },
    "objective_mode": {
      "type": "string",
      "enum": ["total_cost", "co2", "balanced", "utilization"],
      "default": "total_cost"
    },
    "objective_preset": {
      "type": ["string", "null"],
      "enum": ["cost", "co2", "balanced", "utilization", null]
    },
    "time_limit_sec": { "type": "integer", "minimum": 1, "default": 300 },
    "mip_gap": { "type": "number", "minimum": 0, "default": 0.02 },
    "alns_iterations": { "type": "integer", "minimum": 1, "default": 2000 },
    "max_start_fragments_per_vehicle": { "type": "integer", "minimum": 1 },
    "max_end_fragments_per_vehicle": { "type": "integer", "minimum": 1 },
    "fixed_route_band_mode": { "type": "boolean" },
    "output_vehicle_diagram": { "type": "boolean" },
    "termination_policy": {
      "type": "string",
      "enum": ["time_limit_or_gap"]
    }
  },
  "additionalProperties": false
}

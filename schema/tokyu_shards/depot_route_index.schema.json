{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tokyu_shards/depot_route_index.schema.json",
  "type": "object",
  "required": ["dataset_id", "operator_id", "depots", "routes"],
  "properties": {
    "dataset_id": { "type": "string", "minLength": 1 },
    "operator_id": { "type": "string", "const": "tokyu" },
    "depots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["depot_id", "route_ids"],
        "properties": {
          "depot_id": { "type": "string", "minLength": 1 },
          "route_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route_id", "depot_ids", "available_day_types"],
        "properties": {
          "route_id": { "type": "string", "minLength": 1 },
          "depot_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "available_day_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["weekday", "saturday", "holiday"]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}

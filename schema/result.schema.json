{
  "$id": "https://master-course/schemas/result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptimizationResult",
  "type": "object",
  "required": ["solver_mode", "solver_status", "objective_value", "feasible"],
  "properties": {
    "solver_mode": { "type": "string" },
    "solver_status": { "type": "string" },
    "objective_value": { "type": "number" },
    "objective_mode": { "type": "string" },
    "feasible": { "type": "boolean" },
    "served_trip_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unserved_trip_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "vehicle_paths": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "cost_breakdown": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "objective_components_raw": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "objective_components_weighted": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "objective_weights": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "pv_summary": {
      "type": "object",
      "properties": {
        "pv_generated_kwh": { "type": "number", "minimum": 0 },
        "pv_used_direct_kwh": { "type": "number", "minimum": 0 },
        "pv_curtailed_kwh": { "type": "number", "minimum": 0 },
        "grid_import_kwh": { "type": "number", "minimum": 0 },
        "peak_grid_kw": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "utilization_summary": {
      "type": "object",
      "properties": {
        "fleet_size": { "type": "integer", "minimum": 0 },
        "used_vehicle_count": { "type": "integer", "minimum": 0 },
        "utilization_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "vehicle_diagram": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "vehicle_id": { "type": "string" },
          "legs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": { "type": "string" },
                "start_min": { "type": "integer" },
                "end_min": { "type": "integer" },
                "origin": { "type": ["string", "null"] },
                "destination": { "type": ["string", "null"] },
                "trip_id": { "type": ["string", "null"] }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "soc_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "vehicle_id": { "type": "string" },
          "time_min": { "type": "integer" },
          "soc_percent": { "type": "number" },
          "event_type": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "termination_reason": { "type": ["string", "null"] },
    "effective_limits": {
      "type": "object",
      "additionalProperties": true
    },
    "operator_stats": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "selected": { "type": "integer" },
          "accepted": { "type": "integer" },
          "rejected": { "type": "integer" },
          "reward": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "incumbent_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["iteration", "objective_value", "feasible"],
        "properties": {
          "iteration": { "type": "integer" },
          "objective_value": { "type": "number" },
          "feasible": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

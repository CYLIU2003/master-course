{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "weather_daily_observation.schema.json",
  "title": "DailyWeatherObservation",
  "type": "object",
  "required": [
    "date",
    "station_id",
    "station_name",
    "source",
    "weather_label",
    "tmax_c",
    "tmin_c",
    "sunshine_hours",
    "precipitation_mm",
    "quality_flag"
  ],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "station_id": { "type": "string", "minLength": 1 },
    "station_name": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "weather_label": { "type": ["string", "null"] },
    "tmax_c": { "type": ["number", "null"] },
    "tmin_c": { "type": ["number", "null"] },
    "mean_temp_c": { "type": ["number", "null"] },
    "sunshine_hours": { "type": ["number", "null"], "minimum": 0 },
    "precipitation_mm": { "type": ["number", "null"], "minimum": 0 },
    "daylight_note": { "type": ["string", "null"] },
    "quality_flag": { "enum": ["ok", "missing", "estimated", "partial"] },
    "raw_url": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}

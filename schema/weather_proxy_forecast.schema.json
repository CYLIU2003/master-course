{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "weather_proxy_forecast.schema.json",
  "title": "WeatherProxyForecast",
  "type": "object",
  "required": [
    "version",
    "forecast_type",
    "service_date",
    "station_id",
    "station_name",
    "analog_date",
    "analog_selection_score",
    "analog_selection_method",
    "weather_label",
    "tmax_c",
    "tmin_c",
    "mean_temp_c",
    "sunshine_hours",
    "precipitation_mm",
    "sun_score",
    "rain_risk",
    "heat_load_score",
    "midday_recovery_expectation",
    "operation_mode",
    "no_future_leakage",
    "metadata"
  ],
  "properties": {
    "version": { "const": "historical_analog_v1" },
    "forecast_type": { "const": "historical_analog_v1" },
    "service_date": { "type": "string", "format": "date" },
    "station_id": { "type": "string", "minLength": 1 },
    "station_name": { "type": "string", "minLength": 1 },
    "analog_date": { "type": "string", "format": "date" },
    "analog_selection_score": { "type": "number" },
    "analog_selection_method": { "type": "string", "minLength": 1 },
    "weather_label": { "type": ["string", "null"] },
    "tmax_c": { "type": ["number", "null"] },
    "tmin_c": { "type": ["number", "null"] },
    "mean_temp_c": { "type": ["number", "null"] },
    "sunshine_hours": { "type": ["number", "null"] },
    "precipitation_mm": { "type": ["number", "null"] },
    "sun_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "rain_risk": { "type": "number", "minimum": 0, "maximum": 1 },
    "heat_load_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "midday_recovery_expectation": { "enum": ["high", "medium", "low"] },
    "operation_mode": { "enum": ["aggressive", "normal", "conservative"] },
    "no_future_leakage": { "const": true },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
